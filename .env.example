# ─────────────────────────────────────────────────────
# AI Job Bot — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── FREE AI Brain (Groq — Llama 3.3 70B) ─────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Your Profile ──────────────────────────────────────
PROFILE_NAME=Your Name
PROFILE_EMAIL=your@email.com
PROFILE_PHONE=+91XXXXXXXXXX
PROFILE_LOCATION=Your City
PROFILE_EXP_YEARS=4
PROFILE_TITLE=Java Backend Developer
PROFILE_NOTICE=60 days
PROFILE_CTC_EXP=9-10 LPA
PROFILE_GITHUB=https://github.com/yourusername
PROFILE_SKILLS=Java,Spring Boot,Microservices,AWS,Python,React,REST APIs,JUnit,Mockito
PROFILE_EDUCATION=Your Education

# ── Job Search Config ─────────────────────────────────
SEARCH_KEYWORDS=Java Developer|Java Backend Developer|Spring Boot Developer
SEARCH_LOCATIONS=Noida|Gurgaon|Delhi NCR|Bangalore|Remote
MAX_JOBS_PER_RUN=30
MAX_APPLY_PER_RUN=5
MIN_FIT_SCORE=60

# ── Safety Switch ─────────────────────────────────────
AUTO_SUBMIT=false

# ── Schedule ──────────────────────────────────────────
SCHEDULE_MINUTES=60

# ── Railway ───────────────────────────────────────────
PORT=8000
