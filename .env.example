# ───────────────────────────────────────────────────────────────
# AI Job Bot — Environment Variables
# ───────────────────────────────────────────────────────────────

# ── Groq AI (free, no credit card) ─────────────────────────────
# Get at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Telegram ────────────────────────────────────────────────
# 1. @BotFather on Telegram → /newbot
# 2. @userinfobot → get your Chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Google Custom Search (free 100 searches/day) ───────────────
# 1. https://console.cloud.google.com → Custom Search API → enable → get key
# 2. https://programmablesearchengine.google.com → new engine → search entire web → get CX
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CX=your_google_cx_id

# ── Job Search Config ───────────────────────────────────────
MAX_JOBS_PER_RUN=30
MIN_FIT_SCORE=60
SCHEDULE_MINUTES=60

# ── Railway (auto-set) ──────────────────────────────────────
PORT=8000
