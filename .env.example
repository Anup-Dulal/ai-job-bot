# ─────────────────────────────────────────────────────
# AI Job Bot — Environment Variables (FREE VERSION)
# Only ONE API key needed: Groq (free, no credit card)
# Get it at: https://console.groq.com
# ─────────────────────────────────────────────────────

# ── FREE AI Brain (Groq — Llama 3.3 70B) ─────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Your Profile ──────────────────────────────────────
PROFILE_NAME=Your Name
PROFILE_EMAIL=your@email.com
PROFILE_PHONE=+91XXXXXXXXXX
PROFILE_LOCATION=Your City
PROFILE_EXP_YEARS=4
PROFILE_TITLE=Java Backend Developer
PROFILE_SKILLS=Java,Spring Boot,Microservices,AWS,Python,React,REST APIs,JUnit,Mockito
PROFILE_EDUCATION=Your Education
PROFILE_GITHUB=https://github.com/yourusername

# ── What to Search ────────────────────────────────────
SEARCH_KEYWORDS=Java Developer|Java Backend Developer|Spring Boot Developer
SEARCH_LOCATIONS=Noida|Gurgaon|Delhi NCR|Bangalore|Remote
MAX_JOBS_PER_RUN=30
MAX_APPLY_PER_RUN=5
MIN_FIT_SCORE=60

# ── Safety Switch ─────────────────────────────────────
AUTO_SUBMIT=false

# ── Schedule ──────────────────────────────────────────
SCHEDULE_MINUTES=60

# ── Job Site Credentials ──────────────────────────────
NAUKRI_EMAIL=your@email.com
NAUKRI_PASSWORD=your_naukri_password

INDEED_EMAIL=your@email.com
INDEED_PASSWORD=your_indeed_password

LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_linkedin_password
